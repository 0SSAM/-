// شاشة تفاصيل المنتج
@Composable
fun ProductDetailScreen(
    productId: Int,
    viewModel: HomeViewModel, // يمكن استخدام HomeViewModel لجلب تفاصيل المنتج بناءً على معرفه
    onBackClick: () -> Unit
) {
    // جلب المنتج المحدد من ViewModel
    val product by viewModel.products.collectAsState().value.firstOrNull { it.id == productId }?.let {
        // إذا كان المنتج موجودًا بالفعل في قائمة المنتجات التي تم جلبها
        remember { androidx.compose.runtime.mutableStateOf(it) }
    } ?: run {
        // إذا لم يكن المنتج موجودًا في قائمة المنتجات الحالية، يمكننا جلب تفاصيله بشكل منفصل
        // أو إظهار مؤشر تحميل ورسالة خطأ إذا لم يتم العثور عليه.
        // في هذا المثال، سنفترض أن HomeViewModel سيقوم بتحميل جميع المنتجات أو المنتجات حسب الفئة
        // لذا يجب أن يكون المنتج متاحًا إذا تم تمرير ID صحيح.
        // للتأكد، يمكننا إضافة دالة getProductById في HomeViewModel وجلبها هنا.
        // نظرًا لأن HomeViewModel يدير قائمة المنتجات، سنعتمد على وجود المنتج فيها.
        remember { androidx.compose.runtime.mutableStateOf(null) } // افتراضياً لا يوجد منتج
    }

    // لتجنب جلب المنتج مرة أخرى إذا كان موجودًا في HomeViewModel
    // ولكن لضمان جلب تفاصيله في حال الوصول المباشر أو إعادة إنشاء الشاشة
    // يمكننا استخدام ViewModel مخصص لـ ProductDetailScreen أو إضافة منطق جلب ID في HomeViewModel.
    // لتبسيط المثال، سنعتمد على أن HomeViewModel قد قام بتحميل المنتجات.
    LaunchedEffect(productId) {
        // في حالة كان productId -1 أو المنتج غير موجود، يمكن إظهار خطأ
        if (productId == -1) {
            // إظهار رسالة خطأ أو العودة للشاشة السابقة
            viewModel.sendUiEvent(com.alshawwa.pharmacies.util.UiEvent.ShowSnackbar("معرف المنتج غير صالح."))
            onBackClick()
        }
        // لا نحتاج لجلب المنتج هنا بشكل صريح إذا كان HomeViewModel يدير بالفعل قائمة المنتجات
        // ولكن إذا كان هذا ViewModel مخصصًا، فسيتم استدعاء viewModel.loadProduct(productId)
    }

    Scaffold(
        topBar = {
            TopAppBar(
                title = { Text(product?.name ?: "تفاصيل المنتج") },
                colors = TopAppBarDefaults.topAppBarColors(
                    containerColor = MaterialTheme.colorScheme.primaryContainer,
                    titleContentColor = MaterialTheme.colorScheme.onPrimaryContainer
                ),
                navigationIcon = {
                    IconButton(onClick = onBackClick) {
                        Icon(
                            imageVector = Icons.AutoMirrored.Filled.ArrowBack,
                            contentDescription = "العودة"
                        )
                    }
                }
            )
        }
    ) { paddingValues ->
        Box(
            modifier = Modifier
                .fillMaxSize()
                .padding(paddingValues)
                .verticalScroll(rememberScrollState()),
            contentAlignment = Alignment.Center
        ) {
            if (product == null) {
                // يمكن عرض مؤشر تحميل أو رسالة "المنتج غير موجود"
                CircularProgressIndicator() // أو Text("المنتج غير موجود")
            } else {
                Column(
                    modifier = Modifier
                        .fillMaxWidth()
                        .padding(16.dp),
                    horizontalAlignment = Alignment.CenterHorizontally,
                    verticalArrangement = Arrangement.spacedBy(16.dp)
                ) {
                    // صورة المنتج
                    if (!product!!.imageUrl.isNullOrEmpty()) {
                        AsyncImage(
                            model = product!!.imageUrl,
                            contentDescription = product!!.name,
                            modifier = Modifier
                                .fillMaxWidth()
                                .height(250.dp),
                            contentScale = ContentScale.Fit // Fit لعرض الصورة كاملة
                        )
                    } else {
                        // عرض أيقونة افتراضية إذا لم تتوفر صورة
                        Box(
                            modifier = Modifier
                                .fillMaxWidth()
                                .height(250.dp),
                            contentAlignment = Alignment.Center
                        ) {
                            Icon(
                                imageVector = Icons.Filled.MedicalServices,
                                contentDescription = "لا توجد صورة",
                                modifier = Modifier.size(128.dp),
                                tint = MaterialTheme.colorScheme.outline
                            )
                        }
                    }
                    Spacer(modifier = Modifier.height(8.dp))

                    // اسم المنتج
                    Text(
                        text = product!!.name,
                        style = MaterialTheme.typography.headlineMedium,
                        fontWeight = FontWeight.Bold
                    )

                    // فئة المنتج
                    Text(
                        text = "الفئة: ${product!!.category}",
                        style = MaterialTheme.typography.titleMedium,
                        color = MaterialTheme.colorScheme.primary
                    )

                    // وصف المنتج
                    if (product!!.description.isNotBlank()) {
                        Text(
                            text = product!!.description,
                            style = MaterialTheme.typography.bodyLarge,
                            modifier = Modifier.padding(top = 8.dp)
                        )
                    } else {
                        Text(
                            text = "لا يتوفر وصف لهذا المنتج.",
                            style = MaterialTheme.typography.bodyLarge,
                            color = MaterialTheme.colorScheme.onSurfaceVariant.copy(alpha = 0.7f),
                            modifier = Modifier.padding(top = 8.dp)
                        )
                    }
                }
            }
        }
    }
}
