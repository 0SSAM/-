package com.alshawwa.pharmacies.ui.screens.addproduct

import androidx.lifecycle.ViewModel
import androidx.lifecycle.viewModelScope
import com.alshawwa.pharmacies.data.repository.ProductRepository
import com.alshawwa.pharmacies.data.util.Constants
import com.alshawwa.pharmacies.domain.model.Product
import com.alshawwa.pharmacies.util.UiEvent
import dagger.hilt.android.lifecycle.HiltViewModel
import kotlinx.coroutines.channels.Channel
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.flow.receiveAsFlow
import kotlinx.coroutines.launch
import javax.inject.Inject

// ViewModel لشاشة إضافة منتج جديد
@HiltViewModel
class AddProductViewModel @Inject constructor(
    private val repository: ProductRepository
) : ViewModel() {

    // حالة اسم المنتج
    private val _productName = MutableStateFlow("")
    val productName = _productName.asStateFlow()

    // حالة وصف المنتج
    private val _productDescription = MutableStateFlow("")
    val productDescription = _productDescription.asStateFlow()

    // حالة فئة المنتج
    private val productCategory = MutableStateFlow(Constants.PRODUCTCATEGORIES.first()) // الفئة الافتراضية
    val productCategory = _productCategory.asStateFlow()

    // حالة رابط الصورة
    private val _imageUrl = MutableStateFlow(null)
    val imageUrl = _imageUrl.asStateFlow()

    // حالة التحميل (لزر الإضافة)
    private val _isLoading = MutableStateFlow(false)
    val isLoading = _isLoading.asStateFlow()

    // قناة للأحداث التي يجب إرسالها إلى الواجهة (مثل رسائل التوست أو التنقل)
    private val _uiEvent = Channel()
    val uiEvent = _uiEvent.receiveAsFlow()

    // تحديث اسم المنتج
    fun onProductNameChange(name: String) {
        _productName.value = name
    }

    // تحديث وصف المنتج
    fun onProductDescriptionChange(description: String) {
        _productDescription.value = description
    }

    // تحديث فئة المنتج
    fun onProductCategoryChange(category: String) {
        _productCategory.value = category
    }

    // تحديث رابط الصورة
    fun onImageUrlChange(url: String) {
        _imageUrl.value = if (url.isNotBlank()) url else null
    }

    // معالجة النقر على زر حفظ المنتج
    fun onSaveProductClick() {
        if (productName.value.isBlank() || productCategory.value.isBlank()) {
            sendUiEvent(UiEvent.ShowSnackbar("يرجى ملء اسم المنتج واختيار الفئة."))
            return
        }

        _isLoading.value = true
        viewModelScope.launch {
            val newProduct = Product(
                name = productName.value.trim(),
                description = productDescription.value.trim(),
                category = productCategory.value,
                imageUrl = imageUrl.value
            )
            repository.addProduct(newProduct)
                .onSuccess {
                    sendUiEvent(UiEvent.ShowSnackbar("تم إضافة المنتج بنجاح!"))
                    sendUiEvent(UiEvent.NavigateBack) // العودة بعد الإضافة
                }
                .onFailure {
                    sendUiEvent(UiEvent.ShowSnackbar("فشل إضافة المنتج: ${it.localizedMessage}"))
                }
            _isLoading.value = false
        }
    }

    // إرسال حدث للواجهة
    private fun sendUiEvent(event: UiEvent) {
        viewModelScope.launch {
            _uiEvent.send(event)
        }
    }
}
