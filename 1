package com.alshawwa.pharmacies.di

import com.alshawwa.pharmacies.data.api.UnsplashApiService
import com.alshawwa.pharmacies.data.util.Constants
import com.jakewharton.retrofit.converter.kotlinx.serialization.asConverterFactory
import dagger.Module
import dagger.Provides
import dagger.hilt.InstallIn
import dagger.hilt.components.SingletonComponent
import kotlinx.serialization.json.Json
import okhttp3.MediaType.Companion.toMediaType
import okhttp3.OkHttpClient
import retrofit2.Retrofit
import java.util.concurrent.TimeUnit
import javax.inject.Singleton

// وحدة Dagger Hilt لتوفير اعتمادات الشبكة
@Module
@InstallIn(SingletonComponent::class)
object NetworkModule {

    // توفير مثيل لـ Json للتعامل مع التسلسل وإلغاء التسلسل
    @Provides
    @Singleton
    fun provideJson(): Json {
        return Json {
            ignoreUnknownKeys = true // تجاهل الحقول غير المعروفة لتجنب الأعطال
            prettyPrint = true // لتنسيق الخرج بشكل مقروء
            isLenient = true // للسماح ببعض التنسيقات غير القياسية
        }
    }

    // توفير مثيل لـ OkHttpClient للتعامل مع طلبات HTTP
    @Provides
    @Singleton
    fun provideOkHttpClient(): OkHttpClient {
        return OkHttpClient.Builder()
            .connectTimeout(30, TimeUnit.SECONDS) // مهلة الاتصال
            .readTimeout(30, TimeUnit.SECONDS)    // مهلة القراءة
            .writeTimeout(30, TimeUnit.SECONDS)   // مهلة الكتابة
            .build()
    }

    // توفير مثيل لـ Retrofit لإنشاء خدمات API
    @Provides
    @Singleton
    fun provideRetrofit(okHttpClient: OkHttpClient, json: Json): Retrofit {
        val contentType = "application/json".toMediaType()
        return Retrofit.Builder()
            .baseUrl(Constants.UNSPLASHBASEURL) // رابط Unsplash API الأساسي
            .client(okHttpClient)
            .addConverterFactory(json.asConverterFactory(contentType)) // استخدام KotlinX Serialization
            .build()
    }

    // توفير مثيل لـ UnsplashApiService
    @Provides
    @Singleton
    fun provideUnsplashApiService(retrofit: Retrofit): UnsplashApiService {
        return retrofit.create(UnsplashApiService::class.java)
    }
}
