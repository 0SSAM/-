package com.alshawwa.pharmacies.ui.screens.productdetail

import androidx.lifecycle.SavedStateHandle
import androidx.lifecycle.ViewModel
import androidx.lifecycle.viewModelScope
import com.alshawwa.pharmacies.data.repository.ProductRepository
import com.alshawwa.pharmacies.data.util.Constants
import com.alshawwa.pharmacies.domain.model.Product
import com.alshawwa.pharmacies.util.UiEvent
import dagger.hilt.android.lifecycle.HiltViewModel
import kotlinx.coroutines.channels.Channel
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.flow.receiveAsFlow
import kotlinx.coroutines.launch
import javax.inject.Inject

// ViewModel لشاشة تفاصيل المنتج
@HiltViewModel
class ProductDetailViewModel @Inject constructor(
    private val repository: ProductRepository,
    savedStateHandle: SavedStateHandle // للحصول على المعرفات من التنقل
) : ViewModel() {

    // المنتج الذي يتم عرضه
    private val _product = MutableStateFlow(null)
    val product = _product.asStateFlow()

    // قناة للأحداث التي يجب إرسالها إلى الواجهة
    private val _uiEvent = Channel()
    val uiEvent = _uiEvent.receiveAsFlow()

    init {
        // جلب معرف المنتج من SavedStateHandle
        val productId = savedStateHandle.get(Constants.PRODUCTIDARG)
        productId?.let { id ->
            if (id != -1) { // التأكد من أن المعرف صالح
                loadProduct(id)
            } else {
                sendUiEvent(UiEvent.ShowSnackbar("معرف المنتج غير صالح."))
            }
        } ?: sendUiEvent(UiEvent.ShowSnackbar("لم يتم توفير معرف المنتج."))
    }

    // دالة لجلب تفاصيل المنتج من المستودع
    private fun loadProduct(productId: Int) {
        viewModelScope.launch {
            try {
                _product.value = repository.getProductById(productId)
                if (_product.value == null) {
                    sendUiEvent(UiEvent.ShowSnackbar("المنتج غير موجود."))
                }
            } catch (e: Exception) {
                sendUiEvent(UiEvent.ShowSnackbar("فشل تحميل تفاصيل المنتج: ${e.localizedMessage}"))
            }
        }
    }

    // إرسال حدث للواجهة
    private fun sendUiEvent(event: UiEvent) {
        viewModelScope.launch {
            _uiEvent.send(event)
        }
    }
}
