import com.alshawwa.pharmacies.data.util.Constants

// بطاقة عرض معلومات الاتصال (رقم الهاتف وواتساب)
@Composable
fun ContactCard(
    phoneNumber: String,
    whatsappNumber: String,
    modifier: Modifier = Modifier
) {
    val context = LocalContext.current

    Card(
        modifier = modifier.fillMaxWidth(),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp),
        colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surfaceContainerHigh)
    ) {
        Column(modifier = Modifier.padding(16.dp)) {
            // الاتصال الهاتفي
            Row(
                modifier = Modifier
                    .fillMaxWidth()
                    .clickable {
                        val intent = Intent(Intent.ACTION_DIAL).apply {
                            data = Uri.parse("tel:$phoneNumber")
                        }
                        try {
                            context.startActivity(intent)
                        } catch (e: Exception) {
                            Toast.makeText(context, "فشل فتح تطبيق الهاتف.", Toast.LENGTH_SHORT).show()
                        }
                    }
                    .padding(vertical = 8.dp),
                verticalAlignment = Alignment.CenterVertically,
                horizontalArrangement = Arrangement.spacedBy(16.dp)
            ) {
                Icon(
                    imageVector = Icons.Filled.Call,
                    contentDescription = "اتصل بنا",
                    tint = MaterialTheme.colorScheme.primary
                )
                Column {
                    Text(
                        text = "اتصل بخدمة العملاء",
                        style = MaterialTheme.typography.titleMedium,
                        color = MaterialTheme.colorScheme.onSurface
                    )
                    Text(
                        text = phoneNumber,
                        style = MaterialTheme.typography.bodyLarge,
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                }
            }
            Spacer(modifier = Modifier.height(8.dp))

            // التواصل عبر واتساب
            Row(
                modifier = Modifier
                    .fillMaxWidth()
                    .clickable {
                        val uri = Uri.parse("https://api.whatsapp.com/send?phone=$whatsappNumber")
                        val intent = Intent(Intent.ACTION_VIEW, uri)
                        try {
                            context.startActivity(intent)
                        } catch (e: Exception) {
                            Toast.makeText(context, "فشل فتح تطبيق واتساب. تأكد من تثبيته.", Toast.LENGTH_SHORT).show()
                        }
                    }
                    .padding(vertical = 8.dp),
                verticalAlignment = Alignment.CenterVertically,
                horizontalArrangement = Arrangement.spacedBy(16.dp)
            ) {
                Icon(
                    imageVector = Icons.Filled.WhatsApp,
                    contentDescription = "تواصل عبر واتساب",
                    tint = MaterialTheme.colorScheme.primary
                )
                Column {
                    Text(
                        text = "تواصل عبر واتساب",
                        style = MaterialTheme.typography.titleMedium,
                        color = MaterialTheme.colorScheme.onSurface
                    )
                    Text(
                        text = whatsappNumber,
                        style = MaterialTheme.typography.bodyLarge,
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )
                }
            }
        }
    }
}
