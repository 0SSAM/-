package com.alshawwa.pharmacies.ui.screens.home

import androidx.lifecycle.ViewModel
import androidx.lifecycle.viewModelScope
import com.alshawwa.pharmacies.data.repository.ProductRepository
import com.alshawwa.pharmacies.domain.model.Product
import com.alshawwa.pharmacies.util.UiEvent
import dagger.hilt.android.lifecycle.HiltViewModel
import kotlinx.coroutines.channels.Channel
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.flow.catch
import kotlinx.coroutines.flow.collectLatest
import kotlinx.coroutines.flow.flatMapLatest
import kotlinx.coroutines.flow.receiveAsFlow
import kotlinx.coroutines.launch
import javax.inject.Inject

// ViewModel للشاشة الرئيسية، يدير حالة عرض المنتجات
@HiltViewModel
class HomeViewModel @Inject constructor(
    private val repository: ProductRepository
) : ViewModel() {

    // الفئة المختارة حاليًا لعرض المنتجات
    private val _selectedCategory = MutableStateFlow("الكل")
    val selectedCategory = _selectedCategory.asStateFlow()

    // قائمة المنتجات التي سيتم عرضها، يتم تحديثها بناءً على الفئة المختارة
    private val _products = MutableStateFlow>(emptyList())
    val products = _products.asStateFlow()

    // حالة التحميل
    private val _isLoading = MutableStateFlow(false)
    val isLoading = _isLoading.asStateFlow()

    // قناة للأحداث التي يجب إرسالها إلى الواجهة (مثل رسائل التوست)
    private val _uiEvent = Channel()
    val uiEvent = _uiEvent.receiveAsFlow()

    init {
        // يتم تفعيل جمع المنتجات عند تهيئة ViewModel
        collectProducts()
    }

    // دالة لجمع المنتجات من المستودع بناءً على الفئة المختارة
    private fun collectProducts() {
        viewModelScope.launch {
            _selectedCategory.flatMapLatest { category ->
                _isLoading.value = true
                if (category == "الكل") {
                    repository.getAllProducts()
                } else {
                    repository.getProductsByCategory(category)
                }
            }
            .catch { e ->
                _isLoading.value = false
                sendUiEvent(UiEvent.ShowSnackbar("خطأ في تحميل المنتجات: ${e.localizedMessage}"))
            }
            .collectLatest { productList ->
                _products.value = productList
                _isLoading.value = false
            }
        }
    }

    // عند اختيار فئة جديدة
    fun onCategorySelected(category: String) {
        _selectedCategory.value = category
    }

    // إرسال حدث للواجهة
    private fun sendUiEvent(event: UiEvent) {
        viewModelScope.launch {
            _uiEvent.send(event)
        }
    }
}
