import com.alshawwa.pharmacies.ui.screens.home.HomeViewModel
import com.alshawwa.pharmacies.ui.screens.productdetail.ProductDetailScreen
import com.alshawwa.pharmacies.ui.screens.trackorders.TrackOrdersScreen

// الرسم البياني للتنقل في التطبيق
@Composable
fun AlShawwaNavGraph(
    navController: NavHostController
) {
    NavHost(
        navController = navController,
        startDestination = Screen.Home.route // الشاشة الابتدائية عند تشغيل التطبيق
    ) {
        // شاشة الرئيسية
        composable(route = Screen.Home.route) {
            val viewModel: HomeViewModel = hiltViewModel()
            HomeScreen(
                viewModel = viewModel,
                onNavigateToAddProduct = {
                    navController.navigate(Screen.AddProduct.route)
                },
                onNavigateToProductDetail = { productId ->
                    navController.navigate(Screen.ProductDetail.createRoute(productId))
                },
                onNavigateToConsultation = {
                    navController.navigate(Screen.Consultation.route)
                },
                onNavigateToTrackOrders = {
                    navController.navigate(Screen.TrackOrders.route)
                },
                onNavigateToComplaints = {
                    navController.navigate(Screen.ComplaintsSuggestions.route)
                }
            )
        }

        // شاشة إضافة منتج جديد
        composable(route = Screen.AddProduct.route) {
            val viewModel: AddProductViewModel = hiltViewModel()
            AddProductScreen(
                viewModel = viewModel,
                onBackClick = { navController.popBackStack() }
            )
        }

        // شاشة تفاصيل المنتج
        composable(
            route = Screen.ProductDetail.route,
            arguments = listOf(navArgument(Constants.PRODUCTIDARG) {
                type = NavType.IntType
                defaultValue = -1 // قيمة افتراضية إذا لم يتم توفير معرف
            })
        ) { backStackEntry ->
            val productId = backStackEntry.arguments?.getInt(Constants.PRODUCTIDARG) ?: -1
            val viewModel: HomeViewModel = hiltViewModel() // يمكن استخدام HomeViewModel لجلب تفاصيل المنتج
            ProductDetailScreen(
                productId = productId,
                viewModel = viewModel,
                onBackClick = { navController.popBackStack() }
            )
        }

        // شاشة الاستشارات الدوائية
        composable(route = Screen.Consultation.route) {
            ConsultationScreen(
                onBackClick = { navController.popBackStack() }
            )
        }

        // شاشة متابعة الطلبات
        composable(route = Screen.TrackOrders.route) {
            TrackOrdersScreen(
                onBackClick = { navController.popBackStack() }
            )
        }

        // شاشة الشكاوى والاقتراحات
        composable(route = Screen.ComplaintsSuggestions.route) {
            ComplaintsSuggestionsScreen(
                onBackClick = { navController.popBackStack() }
            )
        }
    }
}
