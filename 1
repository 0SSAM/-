package com.alshawwa.pharmacies.data.repository

import com.alshawwa.pharmacies.BuildConfig
import com.alshawwa.pharmacies.data.api.UnsplashApiService
import com.alshawwa.pharmacies.data.database.dao.ProductDao
import com.alshawwa.pharmacies.data.database.entities.ProductEntity
import com.alshawwa.pharmacies.domain.model.Product
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.flow.Flow
import kotlinx.coroutines.flow.map
import kotlinx.coroutines.withContext
import javax.inject.Inject
import javax.inject.Singleton

// واجهة لتحديد عمليات مستودع المنتجات
interface ProductRepository {
    fun getAllProducts(): Flow>
    fun getProductsByCategory(category: String): Flow>
    suspend fun addProduct(product: Product): Result
    suspend fun getProductById(productId: Int): Product?
    suspend fun deleteProduct(productId: Int)
}

// تنفيذ مستودع المنتجات باستخدام Room و Unsplash API
@Singleton
class ProductRepositoryImpl @Inject constructor(
    private val productDao: ProductDao,
    private val unsplashApiService: UnsplashApiService
) : ProductRepository {

    // جلب جميع المنتجات وتحويلها من ProductEntity إلى Product
    override fun getAllProducts(): Flow> {
        return productDao.getAllProducts().map { entities ->
            entities.map { it.toDomainModel() }
        }
    }

    // جلب المنتجات حسب الفئة وتحويلها من ProductEntity إلى Product
    override fun getProductsByCategory(category: String): Flow> {
        return productDao.getProductsByCategory(category).map { entities ->
            entities.map { it.toDomainModel() }
        }
    }

    // إضافة منتج جديد، مع محاولة جلب صورة عالية الدقة من Unsplash إذا لم يتم توفير رابط للصورة
    override suspend fun addProduct(product: Product): Result = withContext(Dispatchers.IO) {
        try {
            var imageUrl: String? = product.imageUrl
            // إذا لم يكن هناك رابط صورة، حاول جلب واحدة من Unsplash
            if (imageUrl.isNullOrEmpty()) {
                val unsplashAccessKey = BuildConfig.UNSPLASHACCESSKEY
                if (unsplashAccessKey.isNotEmpty()) {
                    try {
                        val response = unsplashApiService.searchPhotos(
                            query = "${product.name} ${product.category}",
                            clientId = unsplashAccessKey
                        )
                        imageUrl = response.results.firstOrNull()?.urls?.regular
                    } catch (e: Exception) {
                        // تجاهل الخطأ إذا فشل جلب الصورة، لا يجب أن يمنع إضافة المنتج
                        e.printStackTrace()
                        // يمكن تسجيل الخطأ هنا للتحقق لاحقًا
                    }
                } else {
                    // يمكن إظهار تحذير للمطور إذا كان مفتاح API غير موجود
                    println("Unsplash API key is missing. Cannot fetch product images.")
                }
            }

            // إنشاء كيان المنتج وحفظه في قاعدة البيانات
            val productEntity = product.toEntity(imageUrl)
            productDao.insertProduct(productEntity)
            Result.success(Unit)
        } catch (e: Exception) {
            e.printStackTrace()
            Result.failure(e)
        }
    }

    // جلب منتج حسب معرفه وتحويله إلى Product
    override suspend fun getProductById(productId: Int): Product? = withContext(Dispatchers.IO) {
        productDao.getProductById(productId)?.toDomainModel()
    }

    // حذف منتج من قاعدة البيانات
    override suspend fun deleteProduct(productId: Int) = withContext(Dispatchers.IO) {
        productDao.deleteProduct(productId)
    }
}

// دوال تحويل بين Product (Domain Model) و ProductEntity (Database Entity)
fun ProductEntity.toDomainModel(): Product {
    return Product(
        id = this.id,
        name = this.name,
        category = this.category,
        description = this.description,
        imageUrl = this.imageUrl
    )
}

fun Product.toEntity(imageUrl: String? = null): ProductEntity {
    return ProductEntity(
        id = this.id,
        name = this.name,
        category = this.category,
        description = this.description,
        imageUrl = imageUrl ?: this.imageUrl
    )
}
